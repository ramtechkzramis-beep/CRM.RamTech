# Скопируйте в .env.local и подставьте значения из проекта Supabase:
# Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# СЕКРЕТНЫЙ ключ — обходит все политики доступа. Нужен только для раздела
# «Сотрудники» (создание аккаунтов). НИКОГДА не добавляйте префикс NEXT_PUBLIC_
# и не публикуйте этот ключ — он должен существовать только в .env.local
# на сервере и в переменных окружения продакшн-хостинга.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
